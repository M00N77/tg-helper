# Токен control-бота (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# Telegram user_id владельца (узнать у @userinfobot). Только этому юзеру разрешено пользоваться ботом.
OWNER_TELEGRAM_ID=your_telegram_id

# Дополнительные Telegram user_id, которым разрешено пользоваться ботом (через запятую).
# Помимо явного списка, доступ к боту получают участники командных чатов (см. /team).
ALLOWED_TELEGRAM_IDS=

# Ключ шифрования для сессий и API-токенов (Fernet, base64).
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# Строка подключения к PostgreSQL (замените user, password, host, dbname на ваши данные)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Публичный URL для webhook (ngrok или прод домен)
WEBHOOK_BASE_URL=
# Токен ngrok (опционально)
NGROK_AUTHTOKEN=
# Включать ли авто-туннель ngrok
NGROK_ENABLED=false
# Порт для webhook-сервера
WEBHOOK_PORT=8080
